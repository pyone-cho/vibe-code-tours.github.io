---
import { t, getLocale, localizedPath, type Locale } from '../i18n/utils';

const locale: Locale = getLocale(Astro.url.pathname);
const s = t(locale).home;

const cards = [
  { title: s.card1Title, body: s.card1Body },
  { title: s.card2Title, body: s.card2Body },
  { title: s.card3Title, body: s.card3Body },
];
---

<section class="mx-auto max-w-3xl px-5 py-16 text-center sm:px-6 sm:py-20">
  <h1 class="text-4xl font-bold sm:text-5xl">{s.heroTitle}</h1>
  <p class="mt-4 text-xl font-semibold text-accent-700">{s.heroStat}</p>
  <p class="mx-auto mt-4 max-w-prose text-lg text-gray-600">{s.heroSub}</p>
  <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
    <a href={localizedPath('/apply', locale)} class="btn btn-primary">{s.ctaApply}</a>
    <a href={localizedPath('/curriculum', locale)} class="btn btn-secondary">{s.ctaWork}</a>
  </div>
</section>

<section class="mx-auto max-w-5xl px-5 pb-12 sm:px-6">
  <div class="grid gap-4 md:grid-cols-3">
    {cards.map((card) => (
      <div class="card">
        <h2 class="text-lg">{card.title}</h2>
        <p class="mt-2 text-sm text-gray-600">{card.body}</p>
      </div>
    ))}
  </div>
</section>

<section class="mx-auto max-w-5xl px-5 pb-4 sm:px-6">
  <p class="rounded-lg bg-gray-50 px-5 py-4 text-center text-sm text-gray-600">{s.credibility}</p>
</section>
