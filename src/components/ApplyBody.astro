---
import { t, getLocale, type Locale } from '../i18n/utils';

const locale: Locale = getLocale(Astro.url.pathname);
const s = t(locale).apply;
---

<article class="container-prose py-12">
  <div class="inline-block rounded-full bg-gray-200 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gray-700">
    Cohort 1
  </div>
  <h1 class="mt-4 text-3xl sm:text-4xl">{s.heading}</h1>
  <p class="mt-6 text-lg text-gray-700">{s.closedBody}</p>
  <p class="mt-4 font-semibold text-accent-700">{s.nextCohort}</p>

  <h2 class="mt-8 text-xl">{s.notifyHeading}</h2>
  <ul class="mt-3 list-disc space-y-1 pl-5 text-gray-700">
    {s.notifyList.map((item) => <li>{item}</li>)}
  </ul>

  <h2 class="mt-10 text-2xl">{s.lookHeading}</h2>
  <p class="mt-2 text-sm text-gray-500">{s.lookIntro}</p>
  <ul class="mt-3 list-disc space-y-1 pl-5 text-gray-700">
    {s.lookList.map((item) => <li>{item}</li>)}
  </ul>
</article>
